<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IgnaviorLauncher.ViewModels"
        xmlns:views="clr-namespace:IgnaviorLauncher.Views"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="IgnaviorLauncher.MainWindow"
        Title="Ignavior Launcher" Height="693" Width="1036"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        MinWidth="1060" MinHeight="720"
        FontFamily="/Assets/Fonts/Inter.ttf#Inter">

    <Window.Resources>
        <local:ScaleMultiplier x:Key="ScaleMultiplier"/>
        <local:NonNullVisibleConverter x:Key="NonNullConverter"/>
        <BooleanToVisibilityConverter x:Key="VisibilityConverter"/>
        <local:ProgressWidthConverter x:Key="ProgressConverter"/>
        <local:PauseSymbolConverter x:Key="PauseSymbolConverter"/>
        <local:StateVisibilityConverter x:Key="ShowSettingsConverter"/>
        <FontFamily x:Key="Inter-Variable">/Assets/Fonts/Inter-VariableFont_opsz,wght.ttf#Inter</FontFamily>

        <Style x:Key="FlatButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4C000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="CustomToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#CC171717"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource Inter-Variable}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{StaticResource Inter-Variable}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="{StaticResource Inter-Variable}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="RoundedProgressBar" TargetType="{x:Type ProgressBar}">
            <Setter Property="Background" Value="#33000000"/>
            <Setter Property="Foreground" Value="#C4191B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Rectangle x:Name="BackgroundRect"
                                       RadiusX="4" RadiusY="4"
                                       Stretch="Fill">
                                <Rectangle.Fill>
                                    <RadialGradientBrush Center="0.4,0.5" GradientOrigin="0.5,0.5"
                                                          RadiusX="1" RadiusY="0.65">
                                        <GradientStop Color="#C4191B" Offset="0.34"/>
                                        <GradientStop Color="#7E2E2E" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle RadiusX="4" RadiusY="4"
                                       Stroke="#59000000" StrokeThickness="1"
                                       Fill="Transparent"
                                       Margin="0.5"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundRect" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundRect" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Canvas>
            <Rectangle Width="1024" Height="1024"
                       Canvas.Left="-555" Canvas.Top="-583"
                       Opacity="0.5">
                <Rectangle.Fill>
                    <RadialGradientBrush RadiusX="0.5" RadiusY="0.5"
                                         Center="0.5,0.5" GradientOrigin="0.5,0.5">
                        <GradientStop Color="#38CE2F2F" Offset="0.14"/>
                        <GradientStop Color="#00CE2F2F" Offset="0.83"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Canvas>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="58" Margin="32,28,32,0"
                    CornerRadius="4">
                <Border.Background>
                    <ImageBrush ImageSource="/Assets/TopToolbar.png" Stretch="UniformToFill"/>
                </Border.Background>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ListBox x:Name="GamesTabList"
                             ItemsSource="{Binding Games}"
                             SelectedItem="{Binding SelectedGame}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="GamesTabList_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="60" Height="55" Margin="0,0,0,0"
                                        Background="Transparent">
                                    <Grid>
                                        <Border x:Name="HighlightBorder"
                                            Width="60" Height="57"
                                            Background="#21D9D9D9"
                                            CornerRadius="4"
                                            Visibility="Collapsed"/>
                                        <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                            Margin="2.5,1,1,2.5"
                                            Visibility="{Binding Icon, Converter={StaticResource NonNullConverter}}">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,55,50" RadiusX="8" RadiusY="8"/>
                                            </Image.Clip>
                                        </Image>
                                        <TextBlock Text="{Binding Name[0]}" FontSize="24" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding Icon, Converter={StaticResource NonNullConverter}, ConverterParameter=invert}"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="HighlightBorder" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <ToolTip Style="{StaticResource CustomToolTip}" Content="{Binding Name}"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ToolTipService.InitialShowDelay" Value="500"/>
                                <Setter Property="Margin" Value="0,0,13,0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Grid>
                                                <Border x:Name="HighlightBorder"
                                                        Width="60" Height="57"
                                                        Background="#21D9D9D9"
                                                        CornerRadius="4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Visibility="Collapsed"/>
                                                <Border x:Name="RedLine"
                                                        Width="60" Height="3" 
                                                        Background="#ED331F"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,0,0"
                                                        CornerRadius="0,0,3,3"
                                                        Visibility="Collapsed"/>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="HighlightBorder" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="RedLine" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HighlightBorder" Property="Background" Value="#1AD9D9D9"/>
                                                    <Setter TargetName="HighlightBorder" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="1" Margin="32,20,32,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" MinWidth="410" MaxWidth="1200"/>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="1.8*" MinWidth="570" MaxWidth="1400"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding SelectedGame.Name}" 
                               FontFamily="Inter" FontSize="{Binding ChangelogScale, ConverterParameter=42, Converter={StaticResource ScaleMultiplier}}"
                               Foreground="White" Margin="16,0,0,0"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Stretch"/>
                    <TextBlock Grid.Row="1" Text="{Binding SelectedGame.DisplayVersion}"
                               FontFamily="Inter" FontWeight="Medium" FontSize="{Binding ChangelogScale, ConverterParameter=12, Converter={StaticResource ScaleMultiplier}}"
                               Foreground="#CCFFFFFF" Margin="16,5,0,0"/>

                    <Grid Grid.Row="2" VerticalAlignment="Bottom" Margin="30,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ProgressBar Grid.Row="0"
                            Style="{StaticResource RoundedProgressBar}"
                            Value="{Binding SelectedGame.DownloadProgress, Converter={StaticResource ProgressConverter}}"
                            IsIndeterminate="{Binding SelectedGame.IsExtracting}"
                            Minimum="0" Maximum="100"
                            Height="8"
                            Margin="0,0,0,5"
                            HorizontalAlignment="Left"
                            Width="305"
                            Visibility="{Binding SelectedGame.IsDownloading, Converter={StaticResource VisibilityConverter}}"/>
                        <Grid Grid.Row="1" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Width="305" Height="68"
                                Content="{Binding SelectedGame.TextState}"
                                FontFamily="Inter" FontWeight="SemiBold" FontSize="28"
                                Foreground="White"
                                Command="{Binding DataContext.PrimaryActionCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                CommandParameter="{Binding SelectedGame}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PlayButtonStyle}">
                                        <Setter Property="IsEnabled" Value="True"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedGame.IsDownloading}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter Property="Opacity" Value="0.67"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="1"
                            x:Name="SettingsButton"
                            Style="{StaticResource FlatButtonStyle}"
                            Width="40" Height="40"
                            Content="⚙" FontSize="24"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            Cursor="Hand"
                            Visibility="{Binding SelectedGame.TextState, Converter={StaticResource ShowSettingsConverter}}"
                            Click="SettingsButton_Click"/>
                        </Grid>
                    </Grid>
                </Grid>

                <Popup x:Name="SettingsPopup"
                       PlacementTarget="{Binding ElementName=SettingsButton}"
                       Placement="Top"
                       HorizontalOffset="5"
                       VerticalOffset="-5"
                       StaysOpen="False"
                       PopupAnimation="Fade"
                       AllowsTransparency="True">
                    <Border Background="#1E1E1E"
                            CornerRadius="4"
                            BorderBrush="#555"
                            BorderThickness="1"
                            Padding="8">
                        <StackPanel>
                            <Button Content="Open in file explorer"
                                    Margin="0,0,0,3"
                                    Command="{Binding DataContext.OpenExplorerCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="{Binding SelectedGame}"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="MenuItem_Click"/>
                            <Button Content="Verify integrity of game files"
                                    Margin="0,0,0,3"
                                    Command="{Binding DataContext.VerifyIntegrityCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="{Binding SelectedGame}"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="MenuItem_Click"/>
                            <Button Content="Check for updates"
                                    Margin="0,0,0,3"
                                    Command="{Binding DataContext.CheckForUpdatesCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="MenuItem_Click"/>
                            <Button Content="Uninstall game"
                                    Margin="0,0,0,3"
                                    Command="{Binding DataContext.UninstallGameCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    CommandParameter="{Binding SelectedGame}"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="MenuItem_Click"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <ItemsControl ItemsSource="{Binding SelectedGame.PatchNotes}">
                        <ItemsControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ChangelogScale}"
                                            ScaleY="{Binding ChangelogScale}"/>
                        </ItemsControl.LayoutTransform>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:PatchNoteView />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>