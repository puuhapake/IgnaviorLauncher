<Window x:Class="IgnaviorLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IgnaviorLauncher.ViewModels"
        xmlns:views="clr-namespace:IgnaviorLauncher.Views"
        Title="Ignavior Launcher" Height="693" Width="1036"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        MinWidth="1060" MinHeight="720"
        FontFamily="/Assets/Fonts/Inter.ttf#Inter">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <local:ScaleMultiplier x:Key="ScaleMultiplier"/>
        <FontFamily x:Key="Inter-Variable">
            /Assets/Fonts/Inter-VariableFont_opsz,wght.ttf#Inter
        </FontFamily>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Inter-Variable}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource Inter-Variable}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Rectangle x:Name="BackgroundRect"
                                       RadiusX="4" RadiusY="4"
                                       Stretch="Fill">
                                <Rectangle.Fill>
                                    <RadialGradientBrush Center="0.4,0.5" GradientOrigin="0.5,0.5"
                                                          RadiusX="1" RadiusY="0.65">
                                        <GradientStop Color="#C4191B" Offset="0.34"/>
                                        <GradientStop Color="#7E2E2E" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle RadiusX="4" RadiusY="4"
                                       Stroke="#59000000" StrokeThickness="1"
                                       Fill="Transparent"
                                       Margin="0.5"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundRect" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundRect" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Canvas>
            <Rectangle Width="1024" Height="1024"
                       Canvas.Left="-555" Canvas.Top="-583"
                       Opacity="0.5">
                <Rectangle.Fill>
                    <RadialGradientBrush RadiusX="0.5" RadiusY="0.5"
                                         Center="0.5,0.5" GradientOrigin="0.5,0.5">
                        <GradientStop Color="#38CE2F2F" Offset="0.14"/>
                        <GradientStop Color="#00CE2F2F" Offset="0.83"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Canvas>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="58" Margin="32,28,32,0"
                    Background="#33FFFFFF">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ListBox x:Name="GamesTabList"
                             ItemsSource="{Binding Games}"
                             SelectedItem="{Binding SelectedGame}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="GamesTabList_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="58" Height="58" Margin="0,0,13,0"
                                        Background="#4D5D5D5D" CornerRadius="2">
                                    <TextBlock Text="{Binding Name[0]}" 
                                               Foreground="White" FontSize="24"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,13,0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Grid>
                                                <Border x:Name="HighlightBorder"
                                                        Width="58" Height="58"
                                                        Background="#21D9D9D9"
                                                        CornerRadius="2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Visibility="Collapsed"/>
                                                <Border x:Name="RedLine"
                                                        Width="58" Height="2" 
                                                        Background="#ED331F"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,0,0"
                                                        CornerRadius="1"
                                                        Visibility="Collapsed"/>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="HighlightBorder" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="RedLine" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HighlightBorder" Property="Background" Value="#1AD9D9D9"/>
                                                    <Setter TargetName="HighlightBorder" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="1" Margin="32,20,32,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="380" MaxWidth="900"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="2*" MinWidth="570" MaxWidth="1400"/>
                    <ColumnDefinition Width="0.6*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding SelectedGame.Name}" 
                               FontFamily="Inter" FontSize="{Binding ChangelogScale, Converter={StaticResource ScaleMultiplier}, ConverterParameter=42}"
                               Foreground="White" Margin="16,0,0,0"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Stretch"/>
                    <TextBlock Grid.Row="1" Text="{Binding SelectedGame.DisplayVersion}"
                               FontFamily="Inter" FontWeight="Medium" FontSize="{Binding ChangelogScale, Converter={StaticResource ScaleMultiplier}, ConverterParameter=12}"
                               Foreground="#CCFFFFFF" Margin="16,5,0,0"/>
                    <Button Grid.Row="2" Width="305" Height="68"
                            Content="{Binding SelectedGame.TextState}"
                            Style="{StaticResource PlayButtonStyle}"
                            FontFamily="Inter" FontWeight="SemiBold" FontSize="28"
                            Foreground="White"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Left"
                            Margin="30,0,0,20"
                            Command="{Binding DataContext.PrimaryActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding SelectedGame}"
                            />
                </Grid>

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <ItemsControl ItemsSource="{Binding SelectedGame.PatchNotes}">
                        <ItemsControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ChangelogScale}"
                                            ScaleY="{Binding ChangelogScale}"/>
                        </ItemsControl.LayoutTransform>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:PatchNoteView />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>